<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans-3.0.xsd"
       default-autowire="constructor">
    <bean id="jwtBuildFeature" class="de.ndr.teamcity.JwtBuildFeature" />
    <bean id="jwtBuildStartContext" class="de.ndr.teamcity.JwtBuildStartContext" init-method="register" />
    <bean id="jwtPasswordsProvider" class="de.ndr.teamcity.JwtPasswordsProvider" init-method="register" />
    <bean id="jwtBuildParametersProvider" class="de.ndr.teamcity.JwtBuildParametersProvider" init-method="register" />
    <bean id="jwtBuildFeatureAdminPage" class="de.ndr.teamcity.JwtBuildFeatureAdminPage"/>
    <bean id="keyRotationController" class="de.ndr.teamcity.KeyRotationController"/>
    <bean id="wellKnownPublicFilter" class="de.ndr.teamcity.WellKnownPublicFilter"/>
    <bean id="jwtTestController" class="de.ndr.teamcity.JwtTestController"/>

</beans>

